services:
  # =============================================================================
  # Consul Cluster (3-node HA)
  # =============================================================================
  consul-server-1:
    image: hashicorp/consul:1.17
    container_name: consul-server-1
    command: >
      agent -server
      -bootstrap-expect=3
      -node=consul-server-1
      -bind=0.0.0.0
      -client=0.0.0.0
      -datacenter=dc1
      -ui
    ports:
      - "8500:8500"    # HTTP API + UI
      - "8600:8600/udp" # DNS
    volumes:
      - consul-data-1:/consul/data
    networks:
      - treasuryos-network
    healthcheck:
      test: ["CMD", "consul", "members"]
      interval: 10s
      timeout: 5s
      retries: 5

  consul-server-2:
    image: hashicorp/consul:1.17
    container_name: consul-server-2
    command: >
      agent -server
      -bootstrap-expect=3
      -node=consul-server-2
      -bind=0.0.0.0
      -client=0.0.0.0
      -datacenter=dc1
      -retry-join=consul-server-1
    volumes:
      - consul-data-2:/consul/data
    networks:
      - treasuryos-network
    depends_on:
      consul-server-1:
        condition: service_healthy

  consul-server-3:
    image: hashicorp/consul:1.17
    container_name: consul-server-3
    command: >
      agent -server
      -bootstrap-expect=3
      -node=consul-server-3
      -bind=0.0.0.0
      -client=0.0.0.0
      -datacenter=dc1
      -retry-join=consul-server-1
    volumes:
      - consul-data-3:/consul/data
    networks:
      - treasuryos-network
    depends_on:
      consul-server-1:
        condition: service_healthy

  # =============================================================================
  # Kafka + Zookeeper
  # =============================================================================
  zookeeper:
    image: confluentinc/cp-zookeeper:7.5.0
    container_name: zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    ports:
      - "2182:2181"  # Use 2182 to avoid conflict
    volumes:
      - zookeeper-data:/var/lib/zookeeper/data
      - zookeeper-log:/var/lib/zookeeper/log
    networks:
      - treasuryos-network
    healthcheck:
      test: ["CMD", "nc", "-z", "localhost", "2181"]
      interval: 10s
      timeout: 5s
      retries: 5

  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: kafka
    depends_on:
      zookeeper:
        condition: service_healthy
    ports:
      - "19092:9092"  # Use 19092 to avoid conflict
      - "29092:29092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:19092
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: 0
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "true"
    volumes:
      - kafka-data:/var/lib/kafka/data
    networks:
      - treasuryos-network
    healthcheck:
      test: ["CMD", "kafka-broker-api-versions", "--bootstrap-server", "localhost:9092"]
      interval: 10s
      timeout: 10s
      retries: 5

  # =============================================================================
  # PostgreSQL (for historical data)
  # =============================================================================
  postgres:
    image: postgres:16
    container_name: registry-postgres
    environment:
      POSTGRES_USER: registry
      POSTGRES_PASSWORD: registry_dev_password
      POSTGRES_DB: registry
    ports:
      - "15432:5432"  # Use 15432 to avoid conflict with host PostgreSQL
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./migrations:/docker-entrypoint-initdb.d
    networks:
      - treasuryos-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U registry"]
      interval: 10s
      timeout: 5s
      retries: 5

  # =============================================================================
  # Redis (for gateway rate limiting and caching)
  # =============================================================================
  redis:
    image: redis:7.2-alpine
    container_name: redis
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --maxmemory 256mb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    networks:
      - treasuryos-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # =============================================================================
  # Registry Service
  # =============================================================================
  registry-service:
    build:
      context: .
      dockerfile: Dockerfile
      target: development
    container_name: registry-service
    ports:
      - "8080:8080"    # REST API
      - "50051:50051"  # gRPC
    environment:
      # Consul
      CONSUL_HOST: consul-server-1
      CONSUL_PORT: 8500
      # Kafka
      KAFKA_BOOTSTRAP_SERVERS: kafka:29092
      KAFKA_TOPIC_LIFECYCLE: platform.services.lifecycle
      # PostgreSQL
      DATABASE_URL: postgresql://registry:registry_dev_password@postgres:5432/registry
      # Service
      SERVICE_NAME: registry-service
      SERVICE_VERSION: 0.1.0
      LOG_LEVEL: DEBUG
    volumes:
      - ./src:/app/src:ro
      - ./tests:/app/tests:ro
    networks:
      - treasuryos-network
    depends_on:
      consul-server-1:
        condition: service_healthy
      kafka:
        condition: service_healthy
      postgres:
        condition: service_healthy

  # =============================================================================
  # Kafka UI (for debugging)
  # =============================================================================
  kafka-ui:
    image: provectuslabs/kafka-ui:latest
    container_name: kafka-ui
    ports:
      - "8090:8080"
    environment:
      KAFKA_CLUSTERS_0_NAME: treasuryos
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:29092
      KAFKA_CLUSTERS_0_ZOOKEEPER: zookeeper:2181
    networks:
      - treasuryos-network
    depends_on:
      kafka:
        condition: service_healthy

networks:
  treasuryos-network:
    driver: bridge

volumes:
  consul-data-1:
  consul-data-2:
  consul-data-3:
  zookeeper-data:
  zookeeper-log:
  kafka-data:
  postgres-data:
  redis-data:
