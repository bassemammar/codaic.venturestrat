# VentureStrat legal-service - Local Development Environment
SERVICE_NAME=legal-service
SERVICE_VERSION=1.0.0
HOST=0.0.0.0
PORT=8064

# Database
DATABASE_URL=postgresql://venturestrat:venturestrat_dev_password@localhost:15436/venturestrat

# Consul
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC_PREFIX=legal_service

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=console
TRACING_ENABLED=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:8064

# Development
RELOAD=true
PLATFORM_MODE=standalone
