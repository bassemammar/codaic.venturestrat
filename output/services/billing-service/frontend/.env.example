# =============================================================================
# billing - Environment Configuration
# =============================================================================
#
# Copy this file to .env.local for local development overrides.
# Copy this file to .env.production for production builds.
#
# IMPORTANT: Only variables prefixed with VITE_ are exposed to the browser.
# Never store secrets or API keys in VITE_ variables - they will be bundled
# into the client-side JavaScript and visible to anyone.
#
# For sensitive values, use server-side environment variables and proxy
# requests through your backend API.
#
# Generated: 2026-03-10T13:09:44.730263Z
# Generator: codegen-os v1.0.0
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Backend API base URL (used by Vite dev server proxy)
# In production, this is typically handled by your reverse proxy (nginx, etc.)
VITE_API_BASE_URL=http://localhost:8063

# API path prefix for all API requests
# This path will be proxied to the backend during development
VITE_API_PATH_PREFIX=/api

# API request timeout in milliseconds
# Increase for slow networks or large data operations
VITE_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application name (displayed in browser title, navigation, etc.)
VITE_APP_NAME=billing

# Application log level: debug | info | warn | error
# Use 'debug' during development for verbose logging
VITE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable React Query DevTools (development only)
# Set to 'false' to hide DevTools panel
VITE_ENABLE_DEVTOOLS=true

# Enable Mock Service Worker for API mocking
# Useful for frontend development without a running backend
VITE_ENABLE_MOCKS=false

# -----------------------------------------------------------------------------
# Development Server (Vite)
# -----------------------------------------------------------------------------

# These variables are used by Vite dev server, not the application code
# They are NOT prefixed with VITE_ because they're for build-time only

# Development server port
# Change if port 5173 is already in use
# PORT=5173

# Host binding (set to true or 0.0.0.0 for network access)
# HOST=true

# -----------------------------------------------------------------------------
# Build Configuration
# -----------------------------------------------------------------------------

# Build mode: development | production
# Vite sets this automatically based on the command
# NODE_ENV=development

# Source maps in production build
# Set to 'false' to exclude source maps from production bundle
# VITE_SOURCEMAP=true

# -----------------------------------------------------------------------------
# Authentication (if applicable)
# -----------------------------------------------------------------------------

# OAuth/OIDC provider URL (if using external auth)
# VITE_AUTH_PROVIDER_URL=https://auth.example.com

# OAuth client ID (public, safe to expose)
# VITE_AUTH_CLIENT_ID=your-client-id

# Authentication redirect URI
# VITE_AUTH_REDIRECT_URI=http://localhost:5173/callback

# -----------------------------------------------------------------------------
# Analytics & Monitoring (if applicable)
# -----------------------------------------------------------------------------

# Error tracking service DSN (e.g., Sentry)
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Analytics tracking ID (e.g., Google Analytics)
# VITE_ANALYTICS_ID=UA-XXXXXXXXX-X

# =============================================================================
# Usage Instructions
# =============================================================================
#
# 1. Copy this file to create your local configuration:
#    cp .env.example .env.local
#
# 2. Edit .env.local with your settings
#
# 3. Restart the dev server to pick up changes:
#    npm run dev
#
# 4. Access variables in your code:
#    const apiUrl = import.meta.env.VITE_API_BASE_URL;
#
# Environment file priority (highest to lowest):
#   .env.local          - Local overrides (git-ignored)
#   .env.[mode].local   - Mode-specific local overrides (git-ignored)
#   .env.[mode]         - Mode-specific settings
#   .env                - Default settings
#
# See: https://vite.dev/guide/env-and-mode.html
# =============================================================================
