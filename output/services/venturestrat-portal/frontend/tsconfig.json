{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@theme/*": [
        "src/theme/*"
      ],
      "@inve/*": [
        "../../investor-service/frontend/src/*"
      ],
      "@outr/*": [
        "../../outreach-service/frontend/src/*"
      ],
      "@crm/*": [
        "../../crm-service/frontend/src/*"
      ],
      "@bill/*": [
        "../../billing-service/frontend/src/*"
      ]
    }
  },
  "include": [
    "src",
    "../../investor-service/frontend/src",
    "../../outreach-service/frontend/src",
    "../../crm-service/frontend/src",
    "../../billing-service/frontend/src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}