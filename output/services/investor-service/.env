# VentureStrat investor-service - Local Development Environment
COMPOSE_PROJECT_NAME=venturestrat
SERVICE_NAME=investor-service
SERVICE_VERSION=1.0.0
HOST=0.0.0.0
PORT=8059

# Database
DATABASE_URL=postgresql://venturestrat:venturestrat_dev_password@localhost:15436/venturestrat

# Consul
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC_PREFIX=investor_service

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=console
METRICS_ENABLED=true
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4317

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:8059

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Development
RELOAD=true
